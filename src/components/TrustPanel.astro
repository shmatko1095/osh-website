---
import { Check, Cloud } from 'lucide-astro';
interface Props { localTitle: string; onlineTitle: string; local: string[]; online: string[]; }
const { localTitle, onlineTitle, local, online } = Astro.props;
---
<div class="grid overflow-hidden rounded-[28px] border border-white/10 md:grid-cols-2">
  <section class="bg-white p-6 sm:p-8">
    <Check class="text-heat" size={24} aria-hidden="true" />
    <h3 class="mt-5 text-2xl font-bold text-dark">{localTitle}</h3>
    <ul class="mt-6 space-y-3 text-muted">{local.map((item) => <li>{item}</li>)}</ul>
  </section>
  <section class="bg-white/5 p-6 text-white sm:p-8">
    <Cloud class="text-orange-300" size={24} aria-hidden="true" />
    <h3 class="mt-5 text-2xl font-bold">{onlineTitle}</h3>
    <ul class="mt-6 space-y-3 text-white/65">{online.map((item) => <li>{item}</li>)}</ul>
  </section>
</div>
