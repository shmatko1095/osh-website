---
import { Plus } from 'lucide-astro';
import type { FaqItem } from '@/content';

interface Props { items: FaqItem[]; }
const { items } = Astro.props;

function parseAnswer(answer: string) {
  const match = answer.match(/\[([^\]]+)\]\(([^)]+)\)/);

  if (!match) {
    return { before: answer, label: '', href: '', after: '' };
  }

  const [fullMatch, label, href] = match;
  const index = match.index ?? 0;

  return {
    before: answer.slice(0, index),
    label,
    href,
    after: answer.slice(index + fullMatch.length)
  };
}
---

<div class="divide-y divide-line border-y border-line">
  {
    items.map((item) => {
      const answer = parseAnswer(item.answer);

      return (
      <details class="group py-2">
        <summary class="flex min-h-16 cursor-pointer list-none items-center gap-4 py-3 text-left text-lg font-bold text-dark sm:text-xl">
          <span class="grow">{item.question}</span>
          <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-stone text-dark">
            <Plus class="transition-transform duration-200 group-open:rotate-45" size={18} aria-hidden="true" />
          </span>
        </summary>
        <p class="max-w-3xl pb-6 pr-12 text-base leading-7 text-muted">
          {answer.before}
          {answer.href && (
            <a class="font-semibold text-sky-700 underline decoration-sky-300 underline-offset-4 transition-colors duration-200 hover:text-sky-800" href={answer.href}>
              {answer.label}
            </a>
          )}
          {answer.after}
        </p>
      </details>
      );
    })
  }
</div>
