---
import {
  Activity,
  CheckCircle2,
  CloudOff,
  FileText,
  Gauge,
  Home,
  Layers3,
  Package,
  Radio,
  ShieldCheck,
  Smartphone,
  Thermometer,
  WifiOff,
  Wrench,
  Zap
} from 'lucide-astro';
import type { FeatureItem, IconName } from '@/content/site';

interface Props {
  items: FeatureItem[];
  columns?: 'one' | 'two' | 'three';
}

const { items, columns = 'three' } = Astro.props;
const gridClass = columns === 'one' ? '' : columns === 'two' ? 'md:grid-cols-2' : 'md:grid-cols-3';
const iconMap: Record<IconName, typeof CheckCircle2> = {
  activity: Activity,
  check: CheckCircle2,
  cloudOff: CloudOff,
  fileText: FileText,
  gauge: Gauge,
  home: Home,
  layers: Layers3,
  package: Package,
  radio: Radio,
  shield: ShieldCheck,
  smartphone: Smartphone,
  thermometer: Thermometer,
  wifiOff: WifiOff,
  wrench: Wrench,
  zap: Zap
};
---

<div class={`grid gap-4 ${gridClass}`}>
  {
    items.map((item) => {
      const Icon = iconMap[item.icon] ?? CheckCircle2;
      return (
        <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-lg bg-skysoft text-skytrust">
            <Icon size={22} stroke-width={2.4} aria-hidden="true" />
          </div>
          <h3 class="font-heading text-lg font-bold text-ink">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{item.text}</p>
        </article>
      );
    })
  }
</div>
