---
import { Activity, Gauge, Radio, ShieldCheck, Smartphone, Thermometer } from 'lucide-astro';
import type { FeatureItem } from '@/content';

interface Props { items: FeatureItem[]; }
const { items } = Astro.props;
const icons = { thermometer: Thermometer, radio: Radio, activity: Activity, shield: ShieldCheck, smartphone: Smartphone, gauge: Gauge };
---

<div class="grid gap-4 sm:gap-x-10 sm:gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
  {items.map((item) => {
    const Icon = icons[item.icon as keyof typeof icons] ?? Thermometer;
    return (
      <article class="rounded-[24px] border border-line/80 bg-white p-5 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0">
        <div class="flex gap-4 sm:block">
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-stone sm:h-auto sm:w-auto sm:place-items-start sm:rounded-none sm:bg-transparent">
            <Icon class="text-dark" size={26} stroke-width={1.8} aria-hidden="true" />
          </span>
          <div>
            <h3 class="text-lg font-bold leading-6 text-dark sm:mt-5 sm:text-xl sm:leading-tight">{item.title}</h3>
            <p class="mt-2 max-w-none text-sm leading-6 text-muted sm:mt-3 sm:max-w-sm sm:text-base sm:leading-7">{item.text}</p>
          </div>
        </div>
      </article>
    );
  })}
</div>
