---
import type { Lang, LocaleDefinition } from '@/content';

interface Props {
  currentLang: Lang;
  label: string;
  options: Array<LocaleDefinition & { lang: Lang }>;
}

const { currentLang, label, options } = Astro.props;
---

<label class="sr-only" for="language-switcher">{label}</label>
<select
  id="language-switcher"
  data-language-switcher
  class="cursor-pointer rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-bold text-ink transition-colors duration-200 hover:border-skytrust focus-visible:border-skytrust"
  aria-label={label}
>
  {
    options.map((option) => (
      <option value={option.path} selected={currentLang === option.lang}>{option.label}</option>
    ))
  }
</select>

<script>
  document.querySelectorAll<HTMLSelectElement>('[data-language-switcher]').forEach((select) => {
    select.addEventListener('change', () => {
      if (select.value && window.location.pathname !== select.value) {
        window.location.href = select.value;
      }
    });
  });
</script>
