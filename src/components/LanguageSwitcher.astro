---
import { alternateLang, locales, routePath } from '@/content';
import type { Lang, PageKey } from '@/content';

interface Props {
  lang: Lang;
  page: PageKey;
  label: string;
  inverse?: boolean;
}

const { lang, page, label, inverse = false } = Astro.props;
const nextLang = alternateLang(lang);
---

<a
  href={routePath(nextLang, page)}
  hreflang={locales[nextLang].htmlLang}
  aria-label={`${label}: ${locales[nextLang].label}`}
  class={`inline-flex min-h-11 min-w-11 items-center justify-center rounded-full border px-3 text-sm font-bold transition-colors duration-200 ${
    inverse
      ? 'border-white/20 text-white hover:border-white/50 hover:bg-white/10'
      : 'border-line bg-white text-dark hover:border-dark/30 hover:bg-stone'
  }`}
>
  {locales[nextLang].label}
</a>
