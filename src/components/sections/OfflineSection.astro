---
import type { OfflineContent } from '@/content';
import MediaSlot from '@/components/MediaSlot.astro';
import SectionHeading from '@/components/SectionHeading.astro';

interface Props {
  content: OfflineContent;
}

const { content } = Astro.props;
---

<section id="offline" class="border-b border-slate-200 bg-white py-16 sm:py-20">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.95fr_1.05fr] lg:px-8 lg:items-center">
    <MediaSlot media={content.media} />
    <div>
      <SectionHeading eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <article class="rounded-lg border border-slate-200 bg-paper p-5">
          <h3 class="font-heading text-lg font-bold text-ink">{content.localTitle}</h3>
          <ul class="mt-4 space-y-3">
            {content.local.map((item) => <li class="text-sm leading-6 text-muted">{item}</li>)}
          </ul>
        </article>
        <article class="rounded-lg border border-slate-200 bg-paper p-5">
          <h3 class="font-heading text-lg font-bold text-ink">{content.onlineTitle}</h3>
          <ul class="mt-4 space-y-3">
            {content.online.map((item) => <li class="text-sm leading-6 text-muted">{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </div>
</section>
