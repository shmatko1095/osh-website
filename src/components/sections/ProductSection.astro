---
import { CheckCircle2 } from 'lucide-astro';
import type { ProductContent } from '@/content';
import FeatureGrid from '@/components/FeatureGrid.astro';
import MediaSlot from '@/components/MediaSlot.astro';
import SectionHeading from '@/components/SectionHeading.astro';

interface Props {
  content: ProductContent;
}

const { content } = Astro.props;
---

<section id="product" class="border-b border-slate-200 bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
    <div class="mt-10 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="rounded-lg border border-slate-200 bg-paper p-6">
        <p class="mb-5 w-fit rounded-lg border border-orange-200 bg-orange-50 px-3 py-1 text-sm font-bold text-orange-700">
          {content.status}
        </p>
        <h3 class="font-heading text-2xl font-bold text-ink">{content.kitTitle}</h3>
        <ul class="mt-6 space-y-4">
          {
            content.kit.map((item) => (
              <li class="flex gap-3 text-base leading-7 text-muted">
                <CheckCircle2 class="mt-1 shrink-0 text-skytrust" size={20} aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="grid gap-6">
        <MediaSlot media={content.kitMedia} />
        <MediaSlot media={content.closeupMedia} />
      </div>
    </div>
    <div class="mt-6">
      <FeatureGrid items={content.features} />
    </div>
  </div>
</section>
