---
import type { SolutionContent } from '@/content';
import MediaSlot from '@/components/MediaSlot.astro';
import SectionHeading from '@/components/SectionHeading.astro';

interface Props {
  content: SolutionContent;
}

const { content } = Astro.props;
---

<section id="solution" class="border-b border-slate-200 bg-paper py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div>
        <SectionHeading eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
        <div class="mt-10 grid gap-4 md:grid-cols-3">
          {
            content.steps.map((step, index) => (
              <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-skytrust font-heading text-sm font-bold text-white">
                  {index + 1}
                </span>
                <h3 class="font-heading text-lg font-bold text-ink">{step.title}</h3>
                <p class="mt-3 text-sm leading-6 text-muted">{step.text}</p>
              </article>
            ))
          }
        </div>
      </div>
      <MediaSlot media={content.media} />
    </div>
  </div>
</section>
