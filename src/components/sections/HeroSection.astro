---
import { ArrowRight } from 'lucide-astro';
import type { HeroContent } from '@/content';
import MediaSlot from '@/components/MediaSlot.astro';

interface Props {
  content: HeroContent;
}

const { content } = Astro.props;
---

<section class="border-b border-slate-200 bg-paper">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[1fr_0.95fr] lg:px-8 lg:py-20">
    <div class="flex flex-col justify-center">
      <div class="mb-5 flex flex-wrap items-center gap-3">
        <span class="rounded-lg border border-skytrust/25 bg-skysoft px-3 py-1 font-heading text-sm font-bold text-skytrust">
          {content.eyebrow}
        </span>
        <span class="rounded-lg border border-orange-200 bg-orange-50 px-3 py-1 text-sm font-bold text-orange-700">
          {content.status}
        </span>
      </div>
      <h1 class="max-w-4xl text-5xl font-bold leading-[1.05] text-ink sm:text-6xl lg:text-7xl">{content.title}</h1>
      <p class="mt-6 max-w-2xl text-xl leading-9 text-muted">{content.lead}</p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href="#scenario"
          class="inline-flex cursor-pointer items-center gap-2 rounded-lg bg-heat px-5 py-3 font-heading text-base font-bold text-white transition-colors duration-200 hover:bg-orange-600"
        >
          {content.cta}
          <ArrowRight size={19} aria-hidden="true" />
        </a>
      </div>
      <dl class="mt-10 grid max-w-2xl gap-3 sm:grid-cols-3">
        {
          content.facts.map((fact) => (
            <div class="rounded-lg border border-slate-200 bg-white p-4">
              <dt class="text-xs font-bold uppercase text-slate-500">{fact.label}</dt>
              <dd class="mt-2 font-heading text-base font-bold text-ink">{fact.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <MediaSlot media={content.media} priority />
  </div>
</section>
