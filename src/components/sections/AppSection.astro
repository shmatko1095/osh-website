---
import type { AppContent } from '@/content';
import MediaSlot from '@/components/MediaSlot.astro';
import SectionHeading from '@/components/SectionHeading.astro';

interface Props {
  content: AppContent;
}

const { content } = Astro.props;
---

<section id="app" class="border-b border-slate-200 bg-paper py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading eyebrow={content.eyebrow} title={content.title} lead={content.lead} align="center" />
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {content.cards.map((card) => <MediaSlot media={card} />)}
    </div>
  </div>
</section>
