---
import type { TrustContent } from '@/content';
import FeatureGrid from '@/components/FeatureGrid.astro';
import MediaSlot from '@/components/MediaSlot.astro';
import SectionHeading from '@/components/SectionHeading.astro';

interface Props {
  content: TrustContent;
}

const { content } = Astro.props;
---

<section id="trust" class="border-b border-slate-200 bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      <MediaSlot media={content.testingMedia} />
      <MediaSlot media={content.installationMedia} />
    </div>
    <div class="mt-6">
      <FeatureGrid items={content.features} />
    </div>
  </div>
</section>
