---
import type { CompatibilityContent } from '@/content';
import SectionHeading from '@/components/SectionHeading.astro';

interface Props {
  content: CompatibilityContent;
}

const { content } = Astro.props;
---

<section id="compatibility" class="border-b border-slate-200 bg-paper py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <SectionHeading eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
      <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <h3 class="font-heading text-lg font-bold text-ink">{content.levelsTitle}</h3>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {
            content.levels.map((level) => (
              <div class="rounded-lg border border-slate-200 bg-paper px-4 py-3 font-heading text-sm font-bold text-ink">
                {level}
              </div>
            ))
          }
        </div>
        <p class="mt-5 text-sm leading-6 text-muted">{content.note}</p>
      </div>
    </div>
  </div>
</section>
