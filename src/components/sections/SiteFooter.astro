---
import type { FooterContent } from '@/content';
import BrandMark from '@/components/BrandMark.astro';

interface Props {
  content: FooterContent;
}

const { content } = Astro.props;
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-8 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
    <div class="flex items-center gap-3">
      <BrandMark alt={content.logoAlt} />
      <div>
        <p class="font-heading text-lg font-bold text-ink">OSH</p>
        <p class="text-sm leading-6 text-muted">{content.text}</p>
      </div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-paper px-4 py-3 text-sm font-semibold text-muted">
      <span class="font-heading text-xs font-bold text-skytrust">{content.marketplaceId}</span>
      <span class="ml-2">{content.marketplace}</span>
    </div>
  </div>
</footer>
