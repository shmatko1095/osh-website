---
import { ArrowRight, CheckCircle2 } from 'lucide-astro';
import type { Lang } from '@/content/site';
import { site } from '@/content/site';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQ from './FAQ.astro';
import FeatureGrid from './FeatureGrid.astro';
import Header from './Header.astro';
import MediaPlaceholder from './MediaPlaceholder.astro';
import SectionHeading from './SectionHeading.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = site[lang];
const isUk = lang === 'uk';
---

<BaseLayout lang={t.htmlLang} title={t.seo.title} description={t.seo.description} canonicalPath={t.path}>
  <Header currentLang={lang} nav={t.nav} />

  <main>
    <section class="border-b border-slate-200 bg-paper">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[1fr_0.95fr] lg:px-8 lg:py-20">
        <div class="flex flex-col justify-center">
          <div class="mb-5 flex flex-wrap items-center gap-3">
            <span class="rounded-lg border border-skytrust/25 bg-skysoft px-3 py-1 font-heading text-sm font-bold text-skytrust">
              {t.hero.eyebrow}
            </span>
            <span class="rounded-lg border border-orange-200 bg-orange-50 px-3 py-1 text-sm font-bold text-orange-700">
              {t.hero.status}
            </span>
          </div>
          <h1 class="max-w-4xl text-5xl font-bold leading-[1.05] text-ink sm:text-6xl lg:text-7xl">{t.hero.title}</h1>
          <p class="mt-6 max-w-2xl text-xl leading-9 text-muted">{t.hero.lead}</p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a
              href="#scenario"
              class="inline-flex cursor-pointer items-center gap-2 rounded-lg bg-heat px-5 py-3 font-heading text-base font-bold text-white transition-colors duration-200 hover:bg-orange-600"
            >
              {t.hero.cta}
              <ArrowRight size={19} aria-hidden="true" />
            </a>
            <p class="max-w-xl text-sm leading-6 text-muted">{t.hero.note}</p>
          </div>
          <dl class="mt-10 grid max-w-2xl gap-3 sm:grid-cols-3">
            {
              t.hero.facts.map((fact) => (
                <div class="rounded-lg border border-slate-200 bg-white p-4">
                  <dt class="text-xs font-bold uppercase text-slate-500">{fact.label}</dt>
                  <dd class="mt-2 font-heading text-base font-bold text-ink">{fact.value}</dd>
                </div>
              ))
            }
          </dl>
        </div>

        <MediaPlaceholder
          id="PH-01"
          title={isUk ? 'Hero product scene' : 'Hero product scene'}
          description={
            isUk
              ? 'Чистий кадр терморегулятора на стіні як перший візуальний сигнал продукту.'
              : 'Clean thermostat-on-wall scene as the first product signal.'
          }
          aspect="portrait"
        />
      </div>
    </section>

    <section id="scenario" class="border-b border-slate-200 bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <SectionHeading eyebrow={t.scenario.eyebrow} title={t.scenario.title} lead={t.scenario.lead} />
            <div class="mt-8">
              <FeatureGrid items={t.scenario.points} columns="one" />
            </div>
          </div>
          <MediaPlaceholder
            id="PH-02"
            title={isUk ? 'Hallway to bathroom scenario' : 'Hallway to bathroom scenario'}
            description={
              isUk
                ? 'Візуал: настінний блок у коридорі, бездротовий датчик у ванній, різні температури.'
                : 'Visual: wall unit in hallway, wireless sensor in bathroom, different temperatures.'
            }
            aspect="video"
          />
        </div>
      </div>
    </section>

    <section id="solution" class="border-b border-slate-200 bg-paper py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
          <div>
            <SectionHeading eyebrow={t.solution.eyebrow} title={t.solution.title} lead={t.solution.lead} />
            <div class="mt-10 grid gap-4 md:grid-cols-3">
              {
                t.solution.steps.map((step, index) => (
                  <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                    <span class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-skytrust font-heading text-sm font-bold text-white">
                      {index + 1}
                    </span>
                    <h3 class="font-heading text-lg font-bold text-ink">{step.title}</h3>
                    <p class="mt-3 text-sm leading-6 text-muted">{step.text}</p>
                  </article>
                ))
              }
            </div>
          </div>
          <MediaPlaceholder
            id="PH-03"
            title={isUk ? 'Pair, choose, set' : 'Pair, choose, set'}
            description={
              isUk
                ? 'Простий 3-кроковий візуал: датчик, reference room, температура або розклад.'
                : 'Simple 3-step visual: sensor, reference room, temperature or schedule.'
            }
            aspect="square"
          />
        </div>
      </div>
    </section>

    <section id="product" class="border-b border-slate-200 bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow={t.product.eyebrow} title={t.product.title} lead={t.product.lead} />
        <div class="mt-10 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="rounded-lg border border-slate-200 bg-paper p-6">
            <p class="mb-5 w-fit rounded-lg border border-orange-200 bg-orange-50 px-3 py-1 text-sm font-bold text-orange-700">
              {t.product.status}
            </p>
            <h3 class="font-heading text-2xl font-bold text-ink">{isUk ? 'Склад комплекту' : 'Kit contents'}</h3>
            <ul class="mt-6 space-y-4">
              {
                t.product.kit.map((item) => (
                  <li class="flex gap-3 text-base leading-7 text-muted">
                    <CheckCircle2 class="mt-1 shrink-0 text-skytrust" size={20} aria-hidden="true" />
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="grid gap-6">
            <MediaPlaceholder
              id="PH-08"
              title="Starter Kit"
              description={isUk ? 'Кадр майбутньої комплектації без зайвих smart-home коробок.' : 'Future kit contents without extra smart-home boxes.'}
              aspect="video"
            />
            <MediaPlaceholder
              id="PH-04"
              title="Product close-up"
              description={isUk ? 'Крупний план екрана: поточна температура, target, reference sensor.' : 'Close-up screen: current temperature, target, reference sensor.'}
              aspect="video"
            />
          </div>
        </div>
        <div class="mt-6">
          <FeatureGrid items={t.product.features} />
        </div>
      </div>
    </section>

    <section id="app" class="border-b border-slate-200 bg-paper py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow={t.app.eyebrow} title={t.app.title} lead={t.app.lead} align="center" />
        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          {
            t.app.cards.map((card) => (
              <MediaPlaceholder id={card.id} title={card.title} description={card.text} aspect="portrait" />
            ))
          }
        </div>
      </div>
    </section>

    <section id="offline" class="border-b border-slate-200 bg-white py-16 sm:py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.95fr_1.05fr] lg:px-8 lg:items-center">
        <MediaPlaceholder
          id="PH-09"
          title={isUk ? 'Offline behavior diagram' : 'Offline behavior diagram'}
          description={
            isUk
              ? 'Схема: хмара недоступна, але локальна логіка опалення продовжує працювати.'
              : 'Diagram: cloud unavailable while local heating logic keeps running.'
          }
          aspect="square"
        />
        <div>
          <SectionHeading eyebrow={t.offline.eyebrow} title={t.offline.title} lead={t.offline.lead} />
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <article class="rounded-lg border border-slate-200 bg-paper p-5">
              <h3 class="font-heading text-lg font-bold text-ink">{t.offline.localTitle}</h3>
              <ul class="mt-4 space-y-3">
                {t.offline.local.map((item) => <li class="text-sm leading-6 text-muted">{item}</li>)}
              </ul>
            </article>
            <article class="rounded-lg border border-slate-200 bg-paper p-5">
              <h3 class="font-heading text-lg font-bold text-ink">{t.offline.onlineTitle}</h3>
              <ul class="mt-4 space-y-3">
                {t.offline.online.map((item) => <li class="text-sm leading-6 text-muted">{item}</li>)}
              </ul>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section id="compatibility" class="border-b border-slate-200 bg-paper py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <SectionHeading eyebrow={t.compatibility.eyebrow} title={t.compatibility.title} lead={t.compatibility.lead} />
          <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <h3 class="font-heading text-lg font-bold text-ink">{isUk ? 'Рівні сумісності' : 'Compatibility levels'}</h3>
            <div class="mt-5 grid gap-3 sm:grid-cols-2">
              {
                t.compatibility.levels.map((level) => (
                  <div class="rounded-lg border border-slate-200 bg-paper px-4 py-3 font-heading text-sm font-bold text-ink">
                    {level}
                  </div>
                ))
              }
            </div>
            <p class="mt-5 text-sm leading-6 text-muted">
              {isUk
                ? 'Кожен майбутній рядок compatibility list має містити модель, firmware, reporting interval, battery level і відомі обмеження.'
                : 'Each future compatibility-list row should include model, firmware, reporting interval, battery level, and known limitations.'}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="trust" class="border-b border-slate-200 bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow={t.trust.eyebrow} title={t.trust.title} lead={t.trust.lead} />
        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          <MediaPlaceholder
            id="PH-10"
            title={isUk ? 'Safety and load testing' : 'Safety and load testing'}
            description={isUk ? 'Реальні фото тестів навантаження, нагріву корпусу або лабораторного стенду.' : 'Real photos of load testing, enclosure temperature, or a lab bench.'}
            aspect="video"
          />
          <MediaPlaceholder
            id="PH-11"
            title={isUk ? 'Installation and frame fit' : 'Installation and frame fit'}
            description={isUk ? 'Візуал сумісності з рамками, підрозетником, глибиною і клемами.' : 'Frame, wall box, depth, and terminal compatibility visual.'}
            aspect="video"
          />
        </div>
        <div class="mt-6">
          <FeatureGrid items={t.trust.features} />
        </div>
      </div>
    </section>

    <section id="faq" class="bg-paper py-16 sm:py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="FAQ"
          title={isUk ? 'Питання, які варто закрити одразу.' : 'Questions worth answering early.'}
          lead={
            isUk
              ? 'Технічна чесність важлива для довіри до нового 230-вольтового пристрою.'
              : 'Technical honesty matters for trust in a new 230 V device.'
          }
          align="center"
        />
        <div class="mt-10">
          <FAQ items={t.faq} />
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white">
    <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-8 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
      <div class="flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-lg border border-slate-300 bg-white font-heading text-[10px] font-bold text-skytrust">
          LOGO
        </span>
        <div>
          <p class="font-heading text-lg font-bold text-ink">OSH</p>
          <p class="text-sm leading-6 text-muted">{t.footer.text}</p>
        </div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-paper px-4 py-3 text-sm font-semibold text-muted">
        <span class="font-heading text-xs font-bold text-skytrust">PH-12</span>
        <span class="ml-2">{t.footer.marketplace}</span>
      </div>
    </div>
  </footer>
</BaseLayout>
