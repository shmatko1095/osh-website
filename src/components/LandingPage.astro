---
import type { Lang } from '@/content';
import { localeOptions, locales, site } from '@/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from './Header.astro';
import AppSection from './sections/AppSection.astro';
import CompatibilitySection from './sections/CompatibilitySection.astro';
import FaqSection from './sections/FaqSection.astro';
import HeroSection from './sections/HeroSection.astro';
import OfflineSection from './sections/OfflineSection.astro';
import ProductSection from './sections/ProductSection.astro';
import ScenarioSection from './sections/ScenarioSection.astro';
import SiteFooter from './sections/SiteFooter.astro';
import SolutionSection from './sections/SolutionSection.astro';
import TrustSection from './sections/TrustSection.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const locale = locales[lang];
const content = site[lang];
---

<BaseLayout lang={locale.htmlLang} title={content.seo.title} description={content.seo.description} canonicalPath={locale.path}>
  <Header
    currentLang={lang}
    homePath={locale.path}
    content={content.header}
    languageOptions={localeOptions}
  />

  <main>
    <HeroSection content={content.hero} />
    <ScenarioSection content={content.scenario} />
    <SolutionSection content={content.solution} />
    <ProductSection content={content.product} />
    <AppSection content={content.app} />
    <OfflineSection content={content.offline} />
    <CompatibilitySection content={content.compatibility} />
    <TrustSection content={content.trust} />
    <FaqSection content={content.faq} />
  </main>

  <SiteFooter content={content.footer} />
</BaseLayout>
