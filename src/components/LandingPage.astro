---
import { ArrowRight, Check, ExternalLink } from 'lucide-astro';
import { productFacts, routePath, site } from '@/content';
import type { Lang } from '@/content';
import BenefitList from './BenefitList.astro';
import CapabilityCard from './CapabilityCard.astro';
import FAQ from './FAQ.astro';
import MediaSlot from './MediaSlot.astro';
import SectionHeading from './SectionHeading.astro';
import SetupSteps from './SetupSteps.astro';
import SiteFrame from './SiteFrame.astro';
import SpecificationGrid from './SpecificationGrid.astro';
import TrustPanel from './TrustPanel.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const content = site[lang].home;
const locale = lang === 'uk' ? 'uk-UA' : 'en-US';
const price = new Intl.NumberFormat(locale).format(productFacts.starterKitPriceUah) + (lang === 'uk' ? ' грн' : ' UAH');
const warranty = `${productFacts.warrantyMonths} ${lang === 'uk' ? 'місяці' : 'months'}`;
---

<SiteFrame lang={lang} page="home">
  <section class="overflow-hidden bg-white">
    <div class="site-container grid gap-8 py-10 sm:gap-12 sm:py-16 lg:grid-cols-[1.05fr_.95fr] lg:items-center lg:py-20">
      <div class="relative z-10 lg:col-start-1 lg:row-start-1">
        <p class="eyebrow text-heat-dark">{content.hero.eyebrow}</p>
        <h1 class="mt-4 max-w-4xl text-[clamp(2.75rem,15vw,6.5rem)] font-extrabold leading-[.92] tracking-[-0.075em] text-dark sm:mt-5 sm:text-[clamp(3rem,7.2vw,6.5rem)] sm:leading-[.94] sm:tracking-[-0.065em]">{content.hero.title}</h1>
        <p class="mt-6 max-w-2xl text-lg leading-7 text-muted sm:mt-7 sm:text-xl sm:leading-8">{content.hero.lead}</p>
      </div>
      <div class="relative lg:col-start-2 lg:row-span-2 lg:row-start-1">
        <div class="absolute -inset-10 rounded-full bg-orange-100/60 blur-3xl sm:-inset-16" aria-hidden="true"></div>
        <div class="relative"><MediaSlot media={content.hero.media} priority /></div>
      </div>
      <div class="relative z-10 lg:col-start-1 lg:row-start-2">
        <div class="mt-2 flex flex-col gap-3 sm:flex-row">
          <a href="#benefits" class="button-primary">{content.hero.primaryCta}<ArrowRight size={18} aria-hidden="true" /></a>
          <a href="#setup" class="button-secondary">{content.hero.secondaryCta}</a>
        </div>
        <div class="mt-8 rounded-[24px] border border-line bg-page/70 p-5 sm:mt-10 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0">
          <ul class="grid gap-3 text-sm font-semibold text-muted sm:flex sm:flex-wrap sm:gap-x-7 sm:border-t sm:border-line sm:pt-6">
            {content.hero.highlights.map((item) => <li class="flex items-center gap-2"><Check class="shrink-0 text-heat-dark" size={17} aria-hidden="true" />{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="benefits" class="section-space bg-page">
    <div class="site-container">
      <SectionHeading {...content.benefits} align="center" />
      <div class="mt-12 sm:mt-16"><BenefitList items={content.benefits.items} /></div>
    </div>
  </section>

  <section id="capabilities" class="section-space overflow-hidden bg-stone">
    <div class="site-container">
      <SectionHeading {...content.capabilities} />
      <div class="mt-10 grid gap-4 sm:mt-12 md:-mx-6 md:flex md:snap-x md:snap-mandatory md:gap-5 md:overflow-x-auto md:px-6 md:pb-3 lg:mx-0 lg:grid lg:grid-cols-4 lg:overflow-visible lg:px-0">
        {content.capabilities.items.map((item) => <CapabilityCard item={item} />)}
      </div>
    </div>
  </section>

  <section id="setup" class="section-space bg-white">
    <div class="site-container grid gap-12 lg:grid-cols-[1.05fr_.95fr] lg:items-center lg:gap-16">
      <div>
        <SectionHeading {...content.setup} />
        <div class="mt-10 sm:mt-12"><SetupSteps steps={content.setup.steps} /></div>
      </div>
      <MediaSlot media={content.setup.media} />
    </div>
  </section>

  <section id="product" class="section-space bg-page">
    <div class="site-container">
      <SectionHeading {...content.kit} />
      <div class="mt-12 grid gap-8 lg:grid-cols-[1.1fr_.9fr] lg:items-stretch">
        <MediaSlot media={content.kit.media} />
        <div class="flex flex-col rounded-[28px] bg-white p-6 sm:p-8">
          <h3 class="text-2xl font-bold text-dark">{content.kit.itemsTitle}</h3>
          <ul class="mt-6 space-y-4 text-base leading-7 text-muted">
            {content.kit.items.map((item) => <li class="flex gap-3"><Check class="mt-1 shrink-0 text-heat-dark" size={18} aria-hidden="true" /><span>{item}</span></li>)}
          </ul>
          <div class="mt-auto pt-10">
            <SpecificationGrid items={[
              { label: content.kit.priceLabel, value: price },
              { label: content.kit.currentLabel, value: `${productFacts.maxCurrentAmp} A` },
              { label: content.kit.warrantyLabel, value: warranty }
            ]} />
            {productFacts.isDraft && <p class="mt-4 text-sm leading-6 text-muted">{content.kit.draftNote}</p>}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space bg-white">
    <div class="site-container grid gap-12 lg:grid-cols-[.9fr_1.1fr] lg:items-center lg:gap-16">
      <div>
        <SectionHeading {...content.installation} />
        {content.installation.points.length > 0 && (
          <div class="mt-10 grid gap-8 sm:grid-cols-3 lg:grid-cols-1">
            {content.installation.points.map((item) => <article class="border-t border-line pt-5"><h3 class="text-xl font-bold text-dark">{item.title}</h3><p class="mt-3 text-base leading-7 text-muted">{item.text}</p></article>)}
          </div>
        )}
      </div>
      <MediaSlot media={content.installation.media} />
    </div>
  </section>

  <section id="trust" class="section-space bg-dark text-white">
    <div class="site-container">
      <SectionHeading {...content.trust} inverse />
      <div class="mt-10 grid gap-6 lg:mt-12 lg:grid-cols-2">
        <div class="order-2 lg:order-1"><MediaSlot media={content.trust.localMedia} /></div>
        <div class="order-1 lg:order-2"><TrustPanel localTitle={content.trust.localTitle} onlineTitle={content.trust.onlineTitle} local={content.trust.local} online={content.trust.online} /></div>
      </div>
    </div>
  </section>

  <section id="faq" class="section-space bg-white">
    <div class="site-container grid gap-12 lg:grid-cols-[.75fr_1.25fr] lg:gap-16">
      <SectionHeading {...content.faq} />
      <FAQ items={content.faq.items} />
    </div>
  </section>

  <section class="bg-white pb-16 sm:pb-20 lg:pb-24">
    <div class="site-container">
      <div class="rounded-[28px] bg-heat px-5 py-8 text-dark sm:rounded-[32px] sm:px-10 sm:py-14 lg:flex lg:items-end lg:justify-between lg:gap-12 lg:p-14">
        <div class="max-w-3xl"><h2 class="section-title">{content.finalCta.title}</h2><p class="mt-4 text-base leading-7 text-dark sm:mt-5 sm:text-lg sm:leading-8">{content.finalCta.text}</p></div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row lg:mt-0">
          <a href={routePath(lang, 'docs')} class="button-secondary border-dark bg-white/30">{content.finalCta.docs}</a>
          <a href={routePath(lang, 'support')} class="button-primary bg-dark text-white hover:bg-black">{content.finalCta.support}<ExternalLink size={17} aria-hidden="true" /></a>
        </div>
      </div>
    </div>
  </section>
</SiteFrame>
