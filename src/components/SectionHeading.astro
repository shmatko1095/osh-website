---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, lead, align = 'left' } = Astro.props;
const alignment = align === 'center' ? 'mx-auto text-center' : '';
---

<div class={`max-w-3xl ${alignment}`}>
  <p class="mb-3 font-heading text-sm font-bold uppercase text-skytrust">{eyebrow}</p>
  <h2 class="text-3xl font-bold leading-tight text-ink sm:text-4xl">{title}</h2>
  <p class="mt-4 text-lg leading-8 text-muted">{lead}</p>
</div>
