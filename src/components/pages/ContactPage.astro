---
import { ArrowUpRight, Mail, MessageCircle } from 'lucide-astro';
import { site, siteConfig } from '@/content';
import type { Lang } from '@/content';
import PageHero from '../PageHero.astro';
import SiteFrame from '../SiteFrame.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const content = site[lang].contact;
---

<SiteFrame lang={lang} page="contact">
  <PageHero eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
  <section class="section-space bg-page">
    <div class="site-container grid gap-6 lg:grid-cols-2">
      <a href={`mailto:${siteConfig.email}`} class="group rounded-[28px] bg-white p-7 sm:p-10"><div class="flex items-start justify-between"><Mail class="text-heat-dark" size={30} aria-hidden="true" /><ArrowUpRight class="text-dark transition-transform group-hover:-translate-y-1 group-hover:translate-x-1" size={26} aria-hidden="true" /></div><h2 class="mt-12 text-3xl font-extrabold tracking-[-0.035em] text-dark">{content.emailTitle}</h2><p class="mt-4 text-base leading-7 text-muted">{content.emailText}</p><p class="mt-7 font-bold text-dark">{siteConfig.email}</p></a>
      <a href={siteConfig.telegramUrl} target="_blank" rel="noreferrer" class="group rounded-[28px] bg-dark p-7 text-white sm:p-10"><div class="flex items-start justify-between"><MessageCircle class="text-orange-300" size={30} aria-hidden="true" /><ArrowUpRight class="text-white transition-transform group-hover:-translate-y-1 group-hover:translate-x-1" size={26} aria-hidden="true" /></div><h2 class="mt-12 text-3xl font-extrabold tracking-[-0.035em]">{content.telegramTitle}</h2><p class="mt-4 text-base leading-7 text-white/65">{content.telegramText}</p><p class="mt-7 font-bold">@shmatko1095</p></a>
    </div>
  </section>
  <section class="section-space bg-white">
    <div class="site-container"><h2 class="section-title text-dark">{content.audiencesTitle}</h2><div class="mt-12 grid gap-8 sm:grid-cols-3">{content.audiences.map((item) => <article class="border-t border-line pt-6"><h3 class="text-xl font-bold text-dark">{item.title}</h3><p class="mt-3 text-base leading-7 text-muted">{item.text}</p></article>)}</div></div>
  </section>
</SiteFrame>
