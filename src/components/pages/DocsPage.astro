---
import { Check, Download } from 'lucide-astro';
import { site } from '@/content';
import type { Lang } from '@/content';
import PageHero from '../PageHero.astro';
import SiteFrame from '../SiteFrame.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const content = site[lang].docs;
---

<SiteFrame lang={lang} page="docs">
  <PageHero eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
  <section class="section-space bg-page">
    <div class="site-container grid gap-12 lg:grid-cols-[.8fr_1.2fr] lg:gap-16">
      <h2 class="section-title text-dark">{content.workflowTitle}</h2>
      <ol class="grid gap-px overflow-hidden rounded-[28px] bg-line sm:grid-cols-2">
        {content.workflowSteps.map((step, index) => <li class="bg-white p-6 sm:p-8"><span class="text-sm font-extrabold text-heat-dark">{String(index + 1).padStart(2, '0')}</span><p class="mt-8 text-xl font-bold text-dark">{step}</p></li>)}
      </ol>
    </div>
  </section>
  <section class="section-space bg-white">
    <div class="site-container">
      <h2 class="section-title text-dark">{content.modesTitle}</h2>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {content.modes.map((mode) => <article class="rounded-3xl bg-stone p-6"><h3 class="text-xl font-bold text-dark">{mode.title}</h3><p class="mt-3 text-base leading-7 text-muted">{mode.text}</p></article>)}
      </div>
    </div>
  </section>
  <section class="section-space bg-dark text-white">
    <div class="site-container">
      <h2 class="section-title">{content.boundariesTitle}</h2>
      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {[{ title: content.localTitle, items: content.local }, { title: content.onlineTitle, items: content.online }].map((group, index) => (
          <article class={`rounded-[28px] p-7 sm:p-9 ${index === 0 ? 'bg-white text-dark' : 'bg-white/5 text-white'}`}>
            <h3 class="text-2xl font-bold">{group.title}</h3>
            <ul class={`mt-6 space-y-4 ${index === 0 ? 'text-muted' : 'text-white/65'}`}>{group.items.map((item) => <li class="flex gap-3"><Check class="mt-0.5 shrink-0 text-orange-300" size={18} aria-hidden="true" />{item}</li>)}</ul>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section-space bg-white">
    <div class="site-container rounded-[28px] bg-stone p-7 sm:p-10 lg:flex lg:items-center lg:justify-between lg:gap-12">
      <div><p class="eyebrow text-heat-dark">PDF / Wiring</p><h2 class="mt-4 text-3xl font-extrabold tracking-[-0.035em] text-dark">{content.downloadsTitle}</h2><p class="mt-4 max-w-3xl text-base leading-7 text-muted">{content.downloadsText}</p></div>
      <Download class="mt-8 text-dark/25 lg:mt-0" size={52} stroke-width={1.4} aria-hidden="true" />
    </div>
  </section>
</SiteFrame>
