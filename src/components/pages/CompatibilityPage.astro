---
import { ArrowRight, Check, Frame, Radio } from 'lucide-astro';
import { productFacts, routePath, site } from '@/content';
import type { Lang } from '@/content';
import PageHero from '../PageHero.astro';
import SiteFrame from '../SiteFrame.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const content = site[lang].compatibility;
---

<SiteFrame lang={lang} page="compatibility">
  <PageHero eyebrow={content.eyebrow} title={content.title} lead={content.lead} />
  <section class="section-space bg-page">
    <div class="site-container grid gap-6 lg:grid-cols-2">
      <article class="rounded-[28px] bg-white p-7 sm:p-9">
        <Frame class="text-heat-dark" size={30} stroke-width={1.8} aria-hidden="true" />
        <h2 class="mt-7 text-3xl font-extrabold tracking-[-0.035em] text-dark">{content.frameTitle}</h2>
        <p class="mt-4 text-base leading-7 text-muted">{content.frameText}</p>
        <p class="mt-8 text-5xl font-extrabold tracking-[-0.06em] text-dark">55 × 55</p>
      </article>
      <article class="rounded-[28px] bg-dark p-7 text-white sm:p-9">
        <Radio class="text-orange-300" size={30} stroke-width={1.8} aria-hidden="true" />
        <h2 class="mt-7 text-3xl font-extrabold tracking-[-0.035em]">{content.sensorTitle}</h2>
        <p class="mt-4 text-base leading-7 text-white/65">{content.sensorText}</p>
      </article>
    </div>
  </section>
  <section class="section-space bg-white">
    <div class="site-container grid gap-12 lg:grid-cols-[1.1fr_.9fr] lg:gap-16">
      <div>
        <div class="overflow-hidden rounded-[28px] border border-line">
          <table class="w-full border-collapse text-left">
            <thead class="bg-stone text-sm text-muted"><tr><th class="px-5 py-4 font-bold sm:px-7">{content.modelLabel}</th><th class="px-5 py-4 font-bold sm:px-7">{content.statusLabel}</th></tr></thead>
            <tbody class="divide-y divide-line">
              {productFacts.supportedSensors.map((sensor) => (
                <tr><td class="px-5 py-5 font-bold text-dark sm:px-7">{sensor.model}</td><td class="px-5 py-5 sm:px-7"><span class={`rounded-full px-3 py-1.5 text-sm font-bold ${sensor.status === 'supported' ? 'bg-green-100 text-green-800' : 'bg-orange-100 text-orange-800'}`}>{content.statuses[sensor.status]}</span></td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div>
        <h2 class="text-3xl font-extrabold tracking-[-0.035em] text-dark">{content.policyTitle}</h2>
        <ul class="mt-7 space-y-4">
          {content.policyItems.map((item) => <li class="flex gap-3 text-base text-muted"><Check class="mt-0.5 shrink-0 text-heat-dark" size={19} aria-hidden="true" />{item}</li>)}
        </ul>
        <a href={routePath(lang, 'support')} class="button-primary mt-9">{content.supportCta}<ArrowRight size={18} aria-hidden="true" /></a>
      </div>
    </div>
  </section>
</SiteFrame>
