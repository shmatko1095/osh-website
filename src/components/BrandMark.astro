---
interface Props {
  inverse?: boolean;
}

const { inverse = false } = Astro.props;
---

<span class="inline-flex items-center gap-2.5" aria-label="OSH">
  <span class={`grid h-9 w-9 place-items-center rounded-full ${inverse ? 'bg-white text-dark' : 'bg-dark text-white'}`} aria-hidden="true">
    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none">
      <path d="M12 3.25c1.1 2.7 4.25 4.35 4.25 8.2a4.25 4.25 0 1 1-8.5 0c0-2.05 1.14-3.85 2.77-5.53.18 1.68.82 2.67 1.48 3.43.67-1.44.76-3.45 0-6.1Z" fill="currentColor" />
      <path d="M12 18.1a2.25 2.25 0 0 0 2.25-2.25c0-1.28-.85-2.25-2.25-3.55-1.4 1.3-2.25 2.27-2.25 3.55A2.25 2.25 0 0 0 12 18.1Z" fill="#F97316" />
    </svg>
  </span>
  <span class={`text-lg font-extrabold tracking-[-0.04em] ${inverse ? 'text-white' : 'text-dark'}`}>OSH</span>
</span>
