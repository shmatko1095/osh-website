---
import type { CapabilityItem } from '@/content';
import MediaSlot from './MediaSlot.astro';
interface Props { item: CapabilityItem; }
const { item } = Astro.props;
---
<article class="min-w-[82vw] snap-start overflow-hidden rounded-[28px] bg-white sm:min-w-[360px] lg:min-w-0">
  <MediaSlot media={item.media} />
  <div class="p-6 sm:p-7">
    <h3 class="text-2xl font-bold text-dark">{item.title}</h3>
    <p class="mt-3 text-base leading-7 text-muted">{item.text}</p>
  </div>
</article>
