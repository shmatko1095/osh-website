---
import type { CapabilityItem } from '@/content';
import MediaSlot from './MediaSlot.astro';
interface Props { item: CapabilityItem; }
const { item } = Astro.props;
---
<article class="min-w-0 snap-start overflow-hidden rounded-[24px] border border-dark/5 bg-white shadow-[0_14px_34px_rgba(18,17,29,0.07)] sm:rounded-[28px] md:min-w-[360px] lg:min-w-0">
  <MediaSlot media={item.media} />
  <div class="p-5 sm:p-7">
    <h3 class="text-xl font-bold text-dark sm:text-2xl">{item.title}</h3>
    <p class="mt-3 text-sm leading-6 text-muted sm:text-base sm:leading-7">{item.text}</p>
  </div>
</article>
