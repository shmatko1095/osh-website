---
interface Props { steps: Array<{ title: string; text: string }>; }
const { steps } = Astro.props;
---
<ol class="grid gap-8 sm:grid-cols-2">
  {steps.map((step, index) => (
    <li class="border-t border-dark/15 pt-5">
      <span class="text-sm font-extrabold text-heat-dark">{String(index + 1).padStart(2, '0')}</span>
      <h3 class="mt-6 text-xl font-bold text-dark">{step.title}</h3>
      <p class="mt-3 text-base leading-7 text-muted">{step.text}</p>
    </li>
  ))}
</ol>
