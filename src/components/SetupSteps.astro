---
interface Props { steps: Array<{ title: string; text: string }>; }
const { steps } = Astro.props;
---
<ol class="grid gap-4 sm:grid-cols-2 sm:gap-8">
  {steps.map((step, index) => (
    <li class="rounded-[24px] border border-line bg-stone/70 p-5 sm:rounded-none sm:border-x-0 sm:border-b-0 sm:border-t sm:border-dark/15 sm:bg-transparent sm:p-0 sm:pt-5">
      <span class="text-sm font-extrabold text-heat-dark">{String(index + 1).padStart(2, '0')}</span>
      <h3 class="mt-5 text-lg font-bold text-dark sm:mt-6 sm:text-xl">{step.title}</h3>
      <p class="mt-3 text-sm leading-6 text-muted sm:text-base sm:leading-7">{step.text}</p>
    </li>
  ))}
</ol>
