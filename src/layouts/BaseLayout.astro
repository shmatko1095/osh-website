---
import '../styles/global.css';

interface Props {
  lang: string;
  title: string;
  description: string;
  canonicalPath: string;
}

const { lang, title, description, canonicalPath } = Astro.props;
const canonicalUrl = Astro.site ? new URL(canonicalPath, Astro.site).toString() : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;500;600;700;800&family=Rubik:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="font-body antialiased">
    <slot />
  </body>
</html>
