---
import '@fontsource-variable/manrope';
import '../styles/global.css';
import ph01Hero from '@/assets/site/ph-01-hero-v1.png';
import { productFacts, routePath, siteConfig } from '@/content';
import type { Lang, PageKey, PageSeo } from '@/content';

interface Props {
  lang: Lang;
  page: PageKey;
  seo: PageSeo;
}

const { lang, page, seo } = Astro.props;
const canonicalUrl = new URL(routePath(lang, page), siteConfig.url).toString();
const ukUrl = new URL(routePath('uk', page), siteConfig.url).toString();
const enUrl = new URL(routePath('en', page), siteConfig.url).toString();
const ogImageUrl = new URL(ph01Hero.src, siteConfig.url).toString();
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Organization', name: siteConfig.name, url: siteConfig.url, email: siteConfig.email },
    { '@type': 'WebSite', name: siteConfig.name, url: siteConfig.url, inLanguage: ['uk', 'en'] },
    {
      '@type': 'Product',
      name: siteConfig.productName,
      brand: { '@type': 'Brand', name: siteConfig.name },
      description: seo.description,
      image: ogImageUrl,
      additionalProperty: [
        { '@type': 'PropertyValue', name: 'Maximum current', value: `${productFacts.maxCurrentAmp} A` },
        { '@type': 'PropertyValue', name: 'Warranty', value: `${productFacts.warrantyMonths} months` }
      ]
    }
  ]
};
---

<!doctype html>
<html lang={lang === 'uk' ? 'uk' : 'en'}>
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-0Q0CG4Z67L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-0Q0CG4Z67L');
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-NGPLGC6J');
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seo.description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#12111D" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="uk" href={ukUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={ukUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OSH" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'uk' ? 'uk_UA' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{seo.title}</title>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NGPLGC6J"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      ></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <slot />
  </body>
</html>
