    "lucide-astro": "0.556.0",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.0",
    "typescript": "5.9.2"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "yaml": "2.9.0"
  }
}
