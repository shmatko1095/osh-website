    "verify": "npm run check && npm run build && npm run check:links && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/manrope": "^5.2.8",
    "astro": "6.4.8",
